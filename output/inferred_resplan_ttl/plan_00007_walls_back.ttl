@prefix bot: <https://w3id.org/bot#> .
@prefix ifc: <https://w3id.org/ifc/IFC4_ADD2#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix resplan: <http://resplan.org/resplan#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

resplan:AdjacencyEdge a rdfs:Class ;
    rdfs:label "Adjacency Edge" ;
    rdfs:comment "Explicit adjacency between two spaces, carrying shared wall metadata." .

resplan:Balcony a rdfs:Class ;
    rdfs:subClassOf resplan:RoomType .

resplan:Bathroom a rdfs:Class ;
    rdfs:subClassOf resplan:RoomType .

resplan:Bedroom a rdfs:Class ;
    rdfs:subClassOf resplan:RoomType .

resplan:EntryNode a rdfs:Class ;
    rdfs:label "Entry Node" ;
    rdfs:comment "A node representing an entry or exit space in the building." ;
    rdfs:subClassOf resplan:Room .

resplan:ExteriorWall a rdfs:Class ;
    rdfs:label "Exterior Wall" ;
    rdfs:comment "An exterior wall of a building." ;
    rdfs:subClassOf ifc:Wall .

resplan:InteriorWall a rdfs:Class ;
    rdfs:label "Interior Wall" ;
    rdfs:comment "An interior wall within a building." ;
    rdfs:subClassOf ifc:Wall .

resplan:Kitchen a rdfs:Class ;
    rdfs:subClassOf resplan:RoomType .

resplan:LivingRoom a rdfs:Class ;
    rdfs:subClassOf resplan:RoomType .

resplan:Opening a rdfs:Class ;
    rdfs:label "Opening" ;
    rdfs:comment "An opening in a wall, such as a door or window." .

resplan:Parking a rdfs:Class ;
    rdfs:subClassOf resplan:RoomType .

resplan:ResPlan a rdfs:Class ;
    rdfs:label "ResPlan" ;
    rdfs:comment "The ResPlan ontology for representing building evacuation plans." ;
    rdfs:subClassOf bot:BuildingInformationModel .

resplan:Room a rdfs:Class ;
    rdfs:label "Room" ;
    rdfs:comment "A room within a building." ;
    rdfs:subClassOf bot:Space .

resplan:RoomType a rdfs:Class ;
    rdfs:label "Room Type" ;
    rdfs:comment "A specific type of room within a building." ;
    rdfs:subClassOf resplan:Room .

resplan:Stair a rdfs:Class ;
    rdfs:subClassOf resplan:RoomType .

resplan:Storage a rdfs:Class ;
    rdfs:subClassOf resplan:RoomType .

resplan:Veranda a rdfs:Class ;
    rdfs:subClassOf resplan:RoomType .

resplan:adjacentTo a owl:ObjectProperty ;
    rdfs:domain bot:Space ;
    rdfs:range bot:Space .

resplan:area a owl:DatatypeProperty ;
    rdfs:comment "Area of an element (room, wall, door, window) in plan units." ;
    rdfs:domain rdfs:Resource ;
    rdfs:range xsd:decimal .

resplan:bboxMaxX a owl:DatatypeProperty ;
    rdfs:comment "Maximum X coordinate of the element bounding box." ;
    rdfs:domain rdfs:Resource ;
    rdfs:range xsd:decimal .

resplan:bboxMaxY a owl:DatatypeProperty ;
    rdfs:comment "Maximum Y coordinate of the element bounding box." ;
    rdfs:domain rdfs:Resource ;
    rdfs:range xsd:decimal .

resplan:bboxMinX a owl:DatatypeProperty ;
    rdfs:comment "Minimum X coordinate of the element bounding box." ;
    rdfs:domain rdfs:Resource ;
    rdfs:range xsd:decimal .

resplan:bboxMinY a owl:DatatypeProperty ;
    rdfs:comment "Minimum Y coordinate of the element bounding box." ;
    rdfs:domain rdfs:Resource ;
    rdfs:range xsd:decimal .

resplan:boundedBy a owl:ObjectProperty ;
    rdfs:domain bot:Space ;
    rdfs:range ifc:Wall .

resplan:centroidX a owl:DatatypeProperty ;
    rdfs:comment "Centroid X coordinate in plan units." ;
    rdfs:domain rdfs:Resource ;
    rdfs:range xsd:decimal .

resplan:centroidY a owl:DatatypeProperty ;
    rdfs:comment "Centroid Y coordinate in plan units." ;
    rdfs:domain rdfs:Resource ;
    rdfs:range xsd:decimal .

resplan:connectedViaDoor a owl:ObjectProperty ;
    rdfs:domain bot:Space ;
    rdfs:range bot:Space .

resplan:connectsSpace a owl:ObjectProperty ;
    rdfs:comment "Associates a door with the spaces connected via that opening." ;
    rdfs:domain resplan:Door ;
    rdfs:range bot:Space .

resplan:datasetName a owl:DatatypeProperty ;
    rdfs:comment "Name of the dataset this plan belongs to." ;
    rdfs:domain resplan:ResPlan ;
    rdfs:range xsd:string .

resplan:derivedFrom a owl:ObjectProperty ;
    rdfs:comment "Inferred structural element derived from an adjacency edge." ;
    rdfs:domain ifc:Wall ;
    rdfs:range resplan:AdjacencyEdge .

resplan:expectedWindow a owl:DatatypeProperty ;
    rdfs:comment "Indicates a room should have at least one window (used when the window instance is missing)." ;
    rdfs:domain bot:Space ;
    rdfs:range xsd:boolean .

resplan:geomJSON a owl:DatatypeProperty ;
    rdfs:comment "GeoJSON geometry serialized as string (polygon/linestring) from source data." ;
    rdfs:domain rdfs:Resource ;
    rdfs:range xsd:string .

resplan:geomWKT a owl:DatatypeProperty ;
    rdfs:comment "Geometry as WKT string for spatial processing." ;
    rdfs:domain rdfs:Resource ;
    rdfs:range xsd:string .

resplan:hasRoomType a owl:ObjectProperty ;
    rdfs:domain bot:Space ;
    rdfs:range resplan:RoomType .

resplan:hasWindow a owl:ObjectProperty ;
    rdfs:domain bot:Space ;
    rdfs:range resplan:Window .

resplan:hostsOpening a owl:ObjectProperty ;
    rdfs:comment "Associates a wall with the opening (door or window) hosted on it." ;
    rdfs:domain ifc:Wall ;
    rdfs:range resplan:Opening .

resplan:isInferred a owl:DatatypeProperty ;
    rdfs:comment "Flags individuals produced by inference/construct." ;
    rdfs:domain rdfs:Resource ;
    rdfs:range xsd:boolean .

resplan:isReachableFrom a owl:ObjectProperty ;
    rdfs:domain bot:Space ;
    rdfs:range resplan:EntryNode .

resplan:jsonPath a owl:DatatypeProperty ;
    rdfs:comment "Path to the exported JSON file." ;
    rdfs:domain resplan:ResPlan ;
    rdfs:range xsd:anyURI .

resplan:length a owl:DatatypeProperty ;
    rdfs:comment "Wall segment length in plan units." ;
    rdfs:domain ifc:Wall ;
    rdfs:range xsd:decimal .

resplan:missingInteriorWall a rdf:Property ;
    rdfs:label "missing interior wall" ;
    rdfs:comment "Indicates that an adjacency edge requires an inferred interior wall." ;
    rdfs:domain resplan:AdjacencyEdge ;
    rdfs:range xsd:boolean .

resplan:netArea a owl:DatatypeProperty ;
    rdfs:comment "Net usable area of the plan in square meters." ;
    rdfs:domain resplan:ResPlan ;
    rdfs:range xsd:decimal .

resplan:openingHeight a owl:DatatypeProperty ;
    rdfs:comment "Opening height in plan units." ;
    rdfs:domain resplan:Opening ;
    rdfs:range xsd:decimal .

resplan:openingSillHeight a owl:DatatypeProperty ;
    rdfs:comment "Sill height or offset from floor for the opening." ;
    rdfs:domain resplan:Opening ;
    rdfs:range xsd:decimal .

resplan:openingWidth a owl:DatatypeProperty ;
    rdfs:comment "Clear width of an opening (door/window) in plan units." ;
    rdfs:domain resplan:Opening ;
    rdfs:range xsd:decimal .

resplan:originX a owl:DatatypeProperty ;
    rdfs:comment "Anchor X coordinate of the element (e.g., wall start or opening origin) in plan units." ;
    rdfs:domain rdfs:Resource ;
    rdfs:range xsd:decimal .

resplan:originY a owl:DatatypeProperty ;
    rdfs:comment "Anchor Y coordinate of the element (e.g., wall start or opening origin) in plan units." ;
    rdfs:domain rdfs:Resource ;
    rdfs:range xsd:decimal .

resplan:planArea a owl:DatatypeProperty ;
    rdfs:comment "Gross floor area of the plan in square meters." ;
    rdfs:domain resplan:ResPlan ;
    rdfs:range xsd:decimal .

resplan:plotPath a owl:DatatypeProperty ;
    rdfs:comment "Path to the visualization plot image file." ;
    rdfs:domain resplan:ResPlan ;
    rdfs:range xsd:anyURI .

resplan:replacesWall a owl:ObjectProperty ;
    rdfs:comment "Links an inferred wall to the wall identifier it replaces or was derived from." ;
    rdfs:domain ifc:Wall ;
    rdfs:range ifc:Wall .

resplan:roomArea a owl:DatatypeProperty ;
    rdfs:comment "Net area of an individual room instance." ;
    rdfs:domain resplan:Room ;
    rdfs:range xsd:decimal .

resplan:rotation a owl:DatatypeProperty ;
    rdfs:comment "Element rotation in plan (degrees or radians, consistent with source JSON)." ;
    rdfs:domain rdfs:Resource ;
    rdfs:range xsd:decimal .

resplan:separatesSpace a owl:ObjectProperty ;
    rdfs:comment "Wall separates the listed spaces (used for inferred walls without explicit geometry)." ;
    rdfs:domain ifc:Wall ;
    rdfs:range bot:Space .

resplan:sharedWall a owl:ObjectProperty ;
    rdfs:domain resplan:AdjacencyEdge ;
    rdfs:range ifc:Wall .

resplan:sharedWallCount a owl:DatatypeProperty ;
    rdfs:comment "Number of wall segments reported as shared between the two spaces in this adjacency." ;
    rdfs:domain resplan:AdjacencyEdge ;
    rdfs:range xsd:integer .

resplan:sourceFile a owl:DatatypeProperty ;
    rdfs:comment "Local file path of the original source (e.g. .pkl file)." ;
    rdfs:domain resplan:ResPlan ;
    rdfs:range xsd:anyURI .

resplan:sourceId a owl:DatatypeProperty ;
    rdfs:comment "Identifier from the source JSON/geometry to keep round-trip mapping intact." ;
    rdfs:domain rdfs:Resource ;
    rdfs:range xsd:string .

resplan:spaceA a owl:ObjectProperty ;
    rdfs:domain resplan:AdjacencyEdge ;
    rdfs:range bot:Space .

resplan:spaceB a owl:ObjectProperty ;
    rdfs:domain resplan:AdjacencyEdge ;
    rdfs:range bot:Space .

resplan:unitType a owl:DatatypeProperty ;
    rdfs:comment "Type of floorplan: residential unit." ;
    rdfs:domain resplan:ResPlan ;
    rdfs:range xsd:string .

resplan:violatesRule a rdf:Property ;
    rdfs:label "violates rule" ;
    rdfs:comment "Links an adjacency edge to the SHACL rule it violates." ;
    rdfs:domain resplan:AdjacencyEdge ;
    rdfs:range sh:NodeShape .

resplan:wallDepth a owl:DatatypeProperty ;
    rdfs:comment "Wall thickness/depth in plan units." ;
    rdfs:domain ifc:Wall ;
    rdfs:range xsd:decimal .

resplan:width a owl:DatatypeProperty ;
    rdfs:comment "Width of a door/window opening; alias of openingWidth for legacy data." ;
    rdfs:domain resplan:Opening ;
    rdfs:range xsd:decimal .

resplan:windowOpening a owl:ObjectProperty ;
    rdfs:comment "Expected window openings for a space, even if the window instance is missing." ;
    rdfs:domain bot:Space ;
    rdfs:range resplan:Window .

