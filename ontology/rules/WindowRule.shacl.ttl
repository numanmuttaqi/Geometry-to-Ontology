@prefix sh:         <http://www.w3.org/ns/shacl#> .
@prefix owl:        <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:       <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:        <http://www.w3.org/2001/XMLSchema#> .
@prefix bot:        <https://w3id.org/bot#> .
@prefix ifc:        <https://w3id.org/ifc/IFC4_ADD2#> .
@prefix igml-core:  <http://www.opengis.net/indoorgml/1.0/core#> .
@prefix igml-nav:   <http://www.opengis.net/indoorgml/1.0/navigation#> .
@prefix resplan:    <http://resplan.org/resplan#> .

### W1: Window is missing in the room
resplan:W1_WindowisMissing
  a sh:NodeShape ;
  rdfs:label "W1: Expected window on this room" ;
  sh:targetClass bot:Space ;
  sh:sparql [
    a sh:SPARQLConstraint ;
    sh:message "One or more expected windows are missing in this room" ;
    sh:select """
      PREFIX resplan: <http://resplan.org/resplan#>
      SELECT DISTINCT ?this WHERE {
        ?this resplan:hasRoomType ?type .
        FILTER (?type NOT IN (resplan:Balcony, resplan:Veranda, resplan:Parking))
        ?this resplan:expectedWindow true .

        # Case 1: explicit expected window openings exist; flag if any are not present.
        {
          FILTER EXISTS { ?this resplan:windowOpening ?slot . }
          FILTER EXISTS {
            ?this resplan:windowOpening ?slot .
            FILTER NOT EXISTS { ?this resplan:hasWindow ?slot }
          }
        }
        UNION
        # Case 2: fallback when only expectedWindow flag exists; require at least one window instance.
        {
          FILTER NOT EXISTS { ?this resplan:windowOpening ?anySlot . }
          FILTER NOT EXISTS {
            ?this resplan:hasWindow ?w .
            ?w a resplan:Window .
          }
        }
      }
    """ ;
  ] .

### W2: Windows must be hosted only on exterior walls
resplan:W2_WindowOnExteriorWallOnly
  a sh:NodeShape ;
  rdfs:label "W: Windows must be mounted on exterior walls" ;
  sh:targetClass resplan:Window ;
  sh:sparql [
    a sh:SPARQLConstraint ;
    sh:message "Window must be mounted on an exterior wall." ;
    sh:select """
      PREFIX resplan: <http://resplan.org/resplan#>
      SELECT ?this WHERE {
        ?wall resplan:hostsOpening ?this .
        FILTER NOT EXISTS {
          ?wall a resplan:ExteriorWall .
        }
      }
    """ ;
  ] .


