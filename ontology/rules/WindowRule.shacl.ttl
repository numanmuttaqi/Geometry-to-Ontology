@prefix sh:         <http://www.w3.org/ns/shacl#> .
@prefix owl:        <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:       <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:        <http://www.w3.org/2001/XMLSchema#> .
@prefix bot:        <https://w3id.org/bot#> .
@prefix ifc:        <https://w3id.org/ifc/IFC4_ADD2#> .
@prefix igml-core:  <http://www.opengis.net/indoorgml/1.0/core#> .
@prefix igml-nav:   <http://www.opengis.net/indoorgml/1.0/navigation#> .
@prefix resplan:    <http://resplan.org/resplan#> .

### W1: 
resplan:W1_MinOneWindow_Habitable
  a sh:NodeShape ;
  rdfs:label "W1: Expected window on this room" ;
  sh:targetClass bot:Space ;
  sh:sparql [
    a sh:SPARQLConstraint ;
    sh:message "Window is missing in this room" ;
    sh:select """
      PREFIX resplan: <http://resplan.org/resplan#>
      SELECT ?this WHERE {
        ?this resplan:hasRoomType ?type .
        FILTER (?type NOT IN (resplan:Balcony, resplan:Veranda, resplan:Parking))
        ?this resplan:windowOpening ?w .
        FILTER NOT EXISTS {
          ?this resplan:hasWindow ?w .
          ?w a resplan:Window .
        }
      }
    """ ;
  ] .


### W2: Bathrooms must have a window (since mechanical ventilation is not modelled)
resplan:W2_BathroomNeedsWindow
  a sh:NodeShape ;
  rdfs:label "W2: Bathrooms must have at least one window" ;
  sh:targetClass bot:Space ;
  sh:sparql [
    a sh:SPARQLConstraint ;
    sh:message "Bathroom has no window recorded on its exterior walls." ;
    sh:select """
      PREFIX resplan: <http://resplan.org/resplan#>
      SELECT ?this WHERE {
        ?this resplan:hasRoomType resplan:Bathroom .
        FILTER NOT EXISTS {
          ?this resplan:hasWindow ?window .
          ?window a resplan:Window .
        }
      }
    """ ;
  ] .

