### W4: Windows must be hosted only on exterior walls
resplan:W4_WindowOnExteriorWallOnly
  a sh:NodeShape ;
  rdfs:label "W4: Windows must be mounted on exterior walls" ;
  sh:targetClass resplan:Window ;
  sh:sparql [
    a sh:SPARQLConstraint ;
    sh:message "Window must be mounted on an exterior wall." ;
    sh:select """
      PREFIX resplan: <http://resplan.org/resplan#>
      SELECT ?this WHERE {
        ?wall resplan:hostsOpening ?this .
        FILTER NOT EXISTS {
          ?wall a resplan:ExteriorWall .
        }
      }
    """ ;
  ] .

### W5: Room has window opening on exterior wall but window is not present
resplan:W5_RoomMissingWindow
  a sh:NodeShape ;
  rdfs:label "W5: window is not present" ;
  sh:targetClass bot:Space ;
  sh:sparql [
    a sh:SPARQLConstraint ;
    sh:message "Room has window opening on exterior wall but window is not present." ;
    sh:select """
      PREFIX resplan: <http://resplan.org/resplan#>
        SELECT ?this WHERE {
            ?this resplan:windowOpening ?expected .
            FILTER NOT EXISTS { 
            ?this resplan:hasWindow ?expected . 
            ?expected a resplan:Window . }
          }
        """ ;
  ] .

