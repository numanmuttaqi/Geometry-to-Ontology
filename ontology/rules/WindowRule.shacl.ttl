@prefix sh:         <http://www.w3.org/ns/shacl#> .
@prefix owl:        <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:       <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:        <http://www.w3.org/2001/XMLSchema#> .
@prefix bot:        <https://w3id.org/bot#> .
@prefix ifc:        <https://w3id.org/ifc/IFC4_ADD2#> .
@prefix igml-core:  <http://www.opengis.net/indoorgml/1.0/core#> .
@prefix igml-nav:   <http://www.opengis.net/indoorgml/1.0/navigation#> .
@prefix resplan:    <http://resplan.org/resplan#> .

### W1: Every habitable room (Living/Bedroom/Kitchen) must have at least one window
resplan:W1_MinOneWindow_Habitable
  a sh:NodeShape ;
  sh:targetClass bot:Space ;
  sh:sparql [
    sh:message "Habitable space (Living/Bedroom/Kitchen) has no window hosted on its walls." ;
    sh:select """
      PREFIX resplan: <http://resplan.org/resplan#>
      SELECT ?this WHERE {
        ?this resplan:hasRoomType ?type .
        FILTER (?type IN (resplan:LivingRoom, resplan:Bedroom, resplan:Kitchen))
        FILTER NOT EXISTS {
          ?this resplan:boundedBy ?wall .
          ?wall resplan:hostsOpening ?window .
          ?window a resplan:Window .
        }
      }
    """ ;
  ] .


### W2: Bathrooms must have a window (since mechanical ventilation is not modelled)
resplan:W2_BathroomNeedsWindow
  a sh:NodeShape ;
  sh:targetClass bot:Space ;
  sh:sparql [
    sh:message "Bathroom has no window hosted on its walls." ;
    sh:select """
      PREFIX resplan: <http://resplan.org/resplan#>
      SELECT ?this WHERE {
        ?this resplan:hasRoomType resplan:Bathroom .
        FILTER NOT EXISTS {
          ?this resplan:boundedBy ?wall .
          ?wall resplan:hostsOpening ?window .
          ?window a resplan:Window .
        }
      }
    """ ;
  ] .

### W3: Habitable rooms must share at least one exterior wall
resplan:W3_HabitableHasExteriorWall
  a sh:NodeShape ;
  sh:targetClass bot:Space ;
  sh:sparql [
    sh:message "Habitable space (Living/Bedroom/Kitchen) has no bounding exterior wall." ;
    sh:select """
      PREFIX resplan: <http://resplan.org/resplan#>
      SELECT ?this WHERE {
        ?this resplan:hasRoomType ?type .
        FILTER (?type IN (resplan:LivingRoom, resplan:Bedroom, resplan:Kitchen))
        FILTER NOT EXISTS {
          ?this resplan:boundedBy ?wall .
          ?wall a resplan:ExteriorWall .
        }
      }
    """ ;
  ] .

### W4: Windows must be hosted only on exterior walls
resplan:W4_WindowOnExteriorWallOnly
  a sh:NodeShape ;
  sh:targetClass resplan:Window ;
  sh:sparql [
    sh:message "Window must be mounted on an exterior wall." ;
    sh:select """
      PREFIX resplan: <http://resplan.org/resplan#>
      SELECT ?this WHERE {
        ?wall resplan:hostsOpening ?this .
        FILTER NOT EXISTS {
          ?wall a resplan:ExteriorWall .
        }
      }
    """ ;
  ] .
