### DW3: Door Missing = If there is a space adjacent with another space via a door 'connectedViaDoor', the door connects spaces
resplan:DW3_MissingDoor a sh:NodeShape ;
    sh:targetClass bot:Space ;
    sh:message "Door must connect exactly two spaces via connected_via_door relationships." ;
    sh:sparql [
        sh:select """
        PREFIX resplan: <http://resplan.org/resplan#>
        PREFIX bot: <https://w3id.org/bot#>
        SELECT DISTINCT ?this ?other ?msg WHERE {
            ?this resplan:connectedViaDoor ?other .
            FILTER (?this != ?other)
            FILTER (STR(?this) < STR(?other))
            FILTER NOT EXISTS {
                ?wall resplan:hostsOpening ?door .
                ?door a resplan:Door .
                ?door resplan:connectsSpace ?this .
                ?door resplan:connectsSpace ?other .
            }
        }
        """ ;
    ] .


### DW4: Wall Missing = Doors must connect exactly two spaces with shared boundary wall
resplan:DW4_DoorsImpliesSharedBoundary a sh:NodeShape ;
    sh:targetClass resplan:Door ;
    sh:property [
        sh:path resplan:connectsSpace ;
        sh:minCount 2 ;
        sh:maxCount 2 ;
    ] ;
    sh:message "Door must connect exactly two spaces with shared boundary wall." ;
    sh:sparql [
        sh:select """
        PREFIX resplan: <http://resplan.org/resplan#>
        SELECT DISTINCT ?this WHERE {
            ?this a resplan:Door .
            ?this resplan:connectsSpace ?a .
            ?this resplan:connectsSpace ?b .
            FILTER (?a != ?b)
            FILTER NOT EXISTS {
                ?wall resplan:hostsOpening ?this .
                ?a resplan:boundedBy ?wall .
                ?b resplan:boundedBy ?wall .
            }
        }
        """ ;
    ] .
