@prefix sh:         <http://www.w3.org/ns/shacl#> .
@prefix owl:        <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:       <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:        <http://www.w3.org/2001/XMLSchema#> .
@prefix bot:        <https://w3id.org/bot#> .
@prefix ifc:        <https://w3id.org/ifc/IFC4_ADD2#> .
@prefix igml-core:  <http://www.opengis.net/indoorgml/1.0/core#> .
@prefix igml-nav:   <http://www.opengis.net/indoorgml/1.0/navigation#> .
@prefix resplan:    <http://resplan.org/resplan#> .

### DW1: Every Door must belong to exactly one wall
resplan:DW1_DoorHasExactlyOneWall a sh:NodeShape ;
    rdfs:label "DW1: Door must be hosted by a wall" ;
    sh:targetClass resplan:Door ;
    sh:property [
        a sh:PropertyShape ;
        sh:path [ sh:inversePath resplan:hostsOpening] ;
        sh:minCount 2 ;
        sh:maxCount 2 ;
        sh:message "This door's wall is missing" ;
    ] .


### DW2: Door Missing = If there is a space adjacent with another space via a door 'connectedViaDoor', the door connects spaces
resplan:DW2_MissingDoor a sh:NodeShape ;
rdfs:label "DW2: Missing door between spaces declared as connectedViaDoor" ;
    sh:targetClass bot:Space ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Door must connect exactly two spaces via connected_via_door relationships." ;
        sh:select """
        PREFIX resplan: <http://resplan.org/resplan#>
        PREFIX bot: <https://w3id.org/bot#>
        SELECT DISTINCT ?this ?other WHERE {
            ?this resplan:connectedViaDoor ?other .
            FILTER (?this != ?other)
            FILTER (STR(?this) < STR(?other))
            FILTER NOT EXISTS {
                ?wall resplan:hostsOpening ?door .
                ?door a resplan:Door .
                ?door resplan:connectsSpace ?this .
                ?door resplan:connectsSpace ?other .
            }
        }
        """ ;
    ] .

### DW3: Wall Missing = Doors must connect exactly two spaces with shared boundary wall
resplan:DW3_DoorsImpliesSharedBoundary a sh:NodeShape ;
    rdfs:label "DW3: Host wall must bound both connected spaces" ;
    sh:targetClass resplan:Door ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Door connects two spaces but their shared boundary wall is missing." ;
        sh:select """
        PREFIX resplan: <http://resplan.org/resplan#>
        SELECT DISTINCT ?this WHERE {
            ?this a resplan:Door .
            ?this resplan:connectsSpace ?a .
            ?this resplan:connectsSpace ?b .
            FILTER (?a != ?b)
            FILTER NOT EXISTS {
                ?wall resplan:hostsOpening ?this .
                ?a resplan:boundedBy ?wall .
                ?b resplan:boundedBy ?wall .
            }
        }
        """ ;
    ] .
