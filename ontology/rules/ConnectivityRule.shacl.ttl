@prefix sh:         <http://www.w3.org/ns/shacl#> .
@prefix owl:        <http://www.w3.org/2002/07/owl#> .
@prefix rdf:        <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:       <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:        <http://www.w3.org/2001/XMLSchema#> .
@prefix bot:        <https://w3id.org/bot#> .
@prefix ifc:        <https://w3id.org/ifc/IFC4_ADD2#> .
@prefix igml-core:  <http://www.opengis.net/indoorgml/1.0/core#> .
@prefix igml-nav:   <http://www.opengis.net/indoorgml/1.0/navigation#> .
@prefix resplan:    <http://resplan.org/resplan#> .

### C01: Each habitable room must be reachable through a sequence door chain from the entry node.
resplan:C01_RoomConnectivity a sh:NodeShape ;
    sh:targetSubjectOf resplan:hasRoomType ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Habitable room is not reachable from front door through door connections." ;
        sh:severity sh:Violation ;
        sh:select """
                PREFIX resplan: <http://resplan.org/resplan#>
                SELECT $this
                WHERE {
                # $this = focus room
                FILTER NOT EXISTS {
                ?entry a resplan:EntryNode .
                ?entry (resplan:ConnectedViaDoor | ^resplan:ConnectedViaDoor)+ $this .
                }
            }
        """ ;
    ] .


### C02: Each bedroom must have access to a bathroom through shared door.
### the example only has bedroom - bathroom direct connection, no hallway.
resplan:C02_BedroomBathroomConnectivity a sh:NodeShape ;
sh:targetSubjectOf resplan:hasRoomType ;
sh:sparql [
    a sh:SPARQLConstraint ;
    sh:message "Bedroom does not have access to a bathroom through shared door." ;
    sh:severity sh:Violation ;
    sh:select """
        PREFIX resplan: <http://resplan.org/resplan#>

        SELECT $this
        WHERE {
            $this resplan:hasRoomType resplan:Bedroom .

            FILTER NOT EXISTS 
            # Bedroom - Bathroom direct connection
                {
                $this (resplan:ConnectedViaDoor | ^resplan:ConnectedViaDoor)+ ?bathroom .
                ?bathroom resplan:hasRoomType resplan:Bathroom .
                }
        }
""" ;
] .

### C03: Kitchen - Dining - Living should be connected directly or through open space.
resplan:C03_KitchenDiningLivingConnectivity a sh:NodeShape ; 
sh:targetSubjectOf resplan:hasRoomType ;
sh:message "Kitchen is not connected to Dining or Living room directly or adjacent with each other." ;
sh:sparql [
    a sh:SPARQLConstraint ;
    sh:message "Kitchen is not connected to Dining or Living room directly or adjacent with each other." ;
    sh:severity sh:Violation ;
    sh:select """"
        PREFIX resplan: <http://resplan.org/resplan#>

        SELECT $this
        WHERE {
            $this resplan:hasRoomType resplan:Kitchen .
            FILTER NOT EXISTS { $this rdf:type owl:Class . }

            ?d a resplan:hasRoomType resplan:DiningRoom .
            ?l a resplan:hasRoomType resplan:LivingRoom .

            # Kitchen adjacent to Dining or Living
            FILTER NOT EXISTS
            {
                $this (resplan:AdjacentTo | ^resplan:AdjacentTo)+ ?d . 
                ?d a resplan:hasRoomType resplan:DiningRoom . 
            }
            UNION
            {
                $this (resplan:AdjacentTo | ^resplan:AdjacentTo)+ ?l .
                ?l a resplan:hasRoomType resplan:LivingRoom .
            }
        }
    """ ;
] .
                
### C04: Private zones (bedrooms, bathrooms) should not be adjacent with public zones (living room, kitchen).
resplan:C04_PrivatePublicSeparation a sh:NodeShape ;
sh:targetSubjectOf resplan:hasRoomType ;
sh:sparql [
    a sh:SPARQLConstraint ;
    sh:message "Private zones (bedrooms, bathrooms) are not separated from public zones (living room, kitchen) by doors or walls." ;
    sh:severity sh:Violation ;
    sh:select """
        PREFIX resplan: <http://resplan.org/resplan#>

        SELECT $this
        WHERE {
            $this resplan:hasRoomType ?ptype .
            FILTER ( ?ptype OM (resplan:Bedroom, resplan:Bathroom) ) .
     
            FILTER EXISTS 
            # Private Area adjacent to Public Area
                {
                $this resplan:AdjacentTo ?pub .
                ?pub resplan:hasRoomType ?pubtype .
                FILTER ( ?pubtype OM (resplan:LivingRoom, 
                                    resplan:Kitchen, 
                                    resplan:Storage, 
                                    resplan:Balcony, 
                                    resplan:Veranda,
                                    resplan:Parking
                                    resplan:Stair
                    ) ) .
                }
        }
""" ;
] .

### C05: Balcony accessed from living room, hallway, or bedroom NOT bathroom
resplan:C05_BalconyAccess a sh:NodeShape ;
sh:targetClass resplan:Balcony ;
sh:message "Balcony is not supposed to have access from bathroom." ;
sh:sparql [
    sh:severity sh:Violation ;
    sh:select """
        PREFIX resplan: <http://resplan.org/resplan#>
      
        SELECT DISTINCT $this
        WHERE {
            $this a resplan:Balcony .
            FILTER NOT EXISTS { $this rdf:type owl:Class . }
            $this (resplan:ConnectedViaDoor | ^resplan:ConnectedViaDoor)+ ?bathroom .
            ?bathroom a resplan:Bathroom .
            }
    """ ;
] .

### C06: Storage room and Utility spaces accessed via hallway or kitchen NOT bedroom
resplan:C06_StorageUtilityAccess a sh:NodeShape ;
sh:targetClass resplan:Storage ;
sh:message "Storage room is not supposed to have direct access from bedroom." ;
sh:sparql [
    sh:severity sh:Violation ;
    sh:select """
        PREFIX resplan: <http://resplan.org/resplan#>
      
        SELECT DISTINCT $this
        WHERE {
            $this a resplan:Storage .
            FILTER NOT EXISTS { $this rdf:type owl:Class . }
            $this (resplan:ConnectedViaDoor | ^resplan:ConnectedViaDoor)+ ?bedroom .
            ?bedroom a resplan:Bedroom .
            }
    """ ;
] .
