@prefix sh:         <http://www.w3.org/ns/shacl#> .
@prefix owl:        <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:       <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:        <http://www.w3.org/2001/XMLSchema#> .
@prefix bot:        <https://w3id.org/bot#> .
@prefix ifc:        <https://w3id.org/ifc/IFC4_ADD2#> .
@prefix igml-core:  <http://www.opengis.net/indoorgml/1.0/core#> .
@prefix igml-nav:   <http://www.opengis.net/indoorgml/1.0/navigation#> .
@prefix resplan:    <http://resplan.org/resplan#> .

###################################################################
# MODELING ASSUMPTIONS
###################################################################
# - Door connectivity is materialized: ?a resplan:connectedViaDoor ?b .
# - "Wall required = door required"
# 1. Room instances and room types
#    - Room instances are things like :LIV-01, :BED-01, :BTH-01, etc.
#    - Room type is given via:
#         ?room resplan:hasRoomType ?roomType .
#      where ?roomType is one of:
#         resplan:LivingRoom, resplan:Kitchen, resplan:Bedroom,
#         resplan:Bathroom, resplan:Dining, resplan:Hallway,
#         resplan:Storage, resplan:Balcony, resplan:Entry, ...
#
# 2. Adjacency between rooms
#    - resplan:AdjacentTo expresses a topological adjacency between
#      two room instances or spatial neighbors. (they share a boundary: InteriorWall).
#    - Adjacency is intended to be symmetric:
#         if A resplan:AdjacentTo B then B resplan:AdjacentTo A.
#    - AdjacencyTo is adjacency between spaces without any wall or door in between (open space)
#
# 3. Doors and door connectivity
#    - Door instances represent door openings, e.g. :DOOR-01.
#    - resplan:connects links a door to each of the two rooms it connects:
#         ?door a resplan:Door ;
#               resplan:connects ?room1 ;
#               resplan:connects ?room2 .
#    - “Door required” in the rules means:
#         there exists a resplan:Door d such that
#            d resplan:connects RoomA
#            d resplan:connects RoomB
#
# 4. Walls and bounding relationships
#    - Wall instances represent wall segments between rooms.
#    - resplan:bounds links a wall to each of the rooms it bounds:
#         ?wall a resplan:Wall ;
#               resplan:bounds ?room1 ;
#               resplan:bounds ?room2 .
#    - “Wall required” in the rules means:
#         there exists a resplan:Wall w such that
#            w resplan:bounds RoomA
#            w resplan:bounds RoomB
#
# 5. Interpretation of constraint phrases:
#    - "Wall preferred / optional door":
#         If RoomA and RoomB are AdjacentTo,
#         then at least one Wall bounds both rooms.
#         A Door between them may or may not exist, but is allowed.
#
#    - "Door required through wall":
#         If RoomA and RoomB are AdjacentTo,
#         then there must be:
#           (a) at least one Wall bounding both rooms, AND
#           (b) at least one Door connecting both rooms.
#
#    - "Open or partial separation":
#         Adjacency between RoomA and RoomB is allowed without a
#         continuous wall barrier. In the SHACL rules here, a violation
#         is raised only if a full wall exists between them AND no door
#         connects them (i.e. adjacency is fully blocked).
#
#    - "Not adjacent":
#         RoomA and RoomB must not be AdjacentTo each other at all.
#
# 6. Targeting only room instances (not room classes)
#    - Node shapes use:
#         sh:targetSubjectsOf resplan:hasRoomType
#      so that only instances that actually appear in a plan
#      (e.g. :LIV-01, :BED-01) are validated, and OWL classes such as
#      resplan:LivingRoom, resplan:Bedroom are not treated as focus nodes.
##################################################################

#################################################################
# GENERIC CHECK: any interior wall in adjacency is missing
#################################################################
resplan:AMissingInteriorWallShape
   a sh:NodeShape ;
   rdfs:label "Adjacency edge missing interior wall" ;
   sh:targetClass resplan:AdjacencyEdge ;
   sh:sparql [
       a sh:SPARQLConstraint ;
       sh:message "Interior wall is missing for adjacency edge." ;
       sh:severity sh:violation ;
       sh:select """
           PREFIX resplan: <http://resplan.org/resplan#>
           SELECT DISTINCT ?this ?w WHERE {
             ?this a resplan:AdjacencyEdge ;
                   resplan:sharedWall ?w ;
                   resplan:spaceA ?s1 ;
                   resplan:spaceB ?s2 .

             FILTER (CONTAINS(STR(?w), "#IN-"))
             FILTER NOT EXISTS { ?w a resplan:InteriorWall . }
             FILTER NOT EXISTS {
               ?rep a resplan:InteriorWall ;
                    resplan:replacesWall ?w .
             }
           }
       """ ;
   ] .


